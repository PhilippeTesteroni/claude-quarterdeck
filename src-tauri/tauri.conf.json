{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Quarterdeck",
  "version": "0.1.0",
  "identifier": "pro.philippgross.quarterdeck",
  "build": {
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run ui:dev",
    "beforeBuildCommand": "npm run ui:build"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "popup",
        "title": "Quarterdeck",
        "url": "popup.html",
        "width": 360,
        "height": 460,
        "minWidth": 360,
        "maxWidth": 360,
        "minHeight": 160,
        "maxHeight": 560,
        "resizable": false,
        "closable": false,
        "decorations": false,
        "skipTaskbar": true,
        "alwaysOnTop": false,
        "visible": false,
        "center": false
      },
      {
        "label": "ask",
        "title": "Quarterdeck",
        "url": "ask.html",
        "width": 420,
        "height": 260,
        "resizable": false,
        "decorations": false,
        "skipTaskbar": true,
        "alwaysOnTop": true,
        "visible": false,
        "focus": false,
        "center": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {}
}
